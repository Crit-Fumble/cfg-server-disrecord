# cfg-server-disrecord gateway — local dev env
#
# Copy to .env and fill in the secrets. The gateway needs Discord bot creds
# for the cfg-server-disrecord application (client_id 1504164101553656028), the bearer
# core-server uses to call gateway, and a Docker socket to spawn workers.
#
# Auth model:
#   - core-server → gateway: shared bearer (DISRECORD_GATEWAY_BEARER below).
#     Same value must be set as DISRECORD_GATEWAY_BEARER in cfg-core-server's env.
#   - worker → core-server: per-session JWT signed by core-server with
#     AUTH_SECRET. Gateway never holds AUTH_SECRET; it relays the JWT from
#     core-server's provisioning request into the worker container env.

# --- Discord bot (gateway only) ---
DISRECORD_DISCORD_TOKEN=
DISRECORD_DISCORD_PUBLIC_KEY=

# --- HTTP API ---
PORT=4400

# --- core-server bridge ---
CORE_SERVER_URL=http://localhost:3001
# Shared bearer for the core-server → gateway control plane.
# Must match DISRECORD_GATEWAY_BEARER in cfg-core-server.
DISRECORD_GATEWAY_BEARER=

# --- Worker container spawn ---
# macOS / Linux default; Docker Desktop on Mac also exposes the socket here.
DOCKER_SOCKET_PATH=/var/run/docker.sock
# Local image tag built by docker build (see docs/RUNBOOK.md).
DISRECORD_WORKER_IMAGE=cfg-server-disrecord:local

LOG_LEVEL=info

# --- Worker-mode vars (set by gateway when spawning a container; not needed in .env for `npm run dev:gateway`) ---
# DISRECORD_GATEWAY_URL=
# DISRECORD_SESSION_TOKEN=                # per-session bearer for worker → gateway SSE audio
# DISRECORD_INSTALLATION_ID=
# DISRECORD_USER_ID=
# DISRECORD_GUILD_ID=
# DISRECORD_CHANNEL_ID=
# DISRECORD_DEEPGRAM_MODE=platform        # platform | byok | disabled
# DISRECORD_DEEPGRAM_KEY=                 # only when mode=byok
# DISRECORD_SIZE=micro                    # nano | micro | small
# CORE_SERVER_TOKEN=                   # per-session JWT for worker → core-server callbacks
