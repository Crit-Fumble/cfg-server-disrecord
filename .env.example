# cfg-server-disrecord worker — local dev env.
#
# In production these env vars are injected by cfg-core-server's worker-spawner
# at session-start; you only need a .env locally if you're running the worker
# entrypoint outside Docker (e.g. for debugging the SSE consumer or Deepgram
# integration against a running core-server).
#
# Every value below is per-session and ephemeral. The worker holds no
# long-lived credentials. CORE_SERVER_TOKEN is a JWT signed by core-server
# with scope='disrecord-worker' and an installationId claim; it gates both
# the SSE opus subscription and the transcript/billing/session-policy
# callbacks.

CORE_SERVER_URL=http://localhost:3001
CORE_SERVER_TOKEN=

DISRECORD_INSTALLATION_ID=
DISRECORD_USER_ID=
DISRECORD_GUILD_ID=
DISRECORD_CHANNEL_ID=
DISRECORD_DEEPGRAM_MODE=platform   # platform | byok | disabled
# DISRECORD_DEEPGRAM_KEY=          # only when mode=byok
DISRECORD_SIZE=micro               # nano | micro | small

LOG_LEVEL=info
