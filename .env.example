# cfg-resesh gateway — local dev env
#
# Copy to .env and fill in the secrets. The gateway requires Discord bot creds
# for the cfg-resesh application (client_id 1504164101553656028), a shared
# bearer secret with cfg-core-server, and a Docker socket to spawn workers.
#
# The same secret bound to CORE_SERVER_AUTH_SECRET below MUST be set as
# RESESH_AUTH_SECRET in cfg-core-server's env. That's the shared bearer used
# in both directions (core-server → gateway, worker → core-server).

# --- Discord bot (gateway only) ---
RESESH_DISCORD_TOKEN=
RESESH_DISCORD_PUBLIC_KEY=

# --- HTTP API ---
PORT=4400

# --- core-server bridge ---
CORE_SERVER_URL=http://localhost:3001
CORE_SERVER_AUTH_SECRET=

# --- Worker container spawn ---
# macOS / Linux default; Docker Desktop on Mac also exposes the socket here.
DOCKER_SOCKET_PATH=/var/run/docker.sock
# Local image tag built by docker build (see docs/RUNBOOK.md).
RESESH_WORKER_IMAGE=cfg-resesh:local

LOG_LEVEL=info

# --- Worker-mode vars (set by gateway when spawning a container; not needed in .env for `npm run dev:gateway`) ---
# RESESH_GATEWAY_URL=
# RESESH_SESSION_TOKEN=
# RESESH_INSTALLATION_ID=
# RESESH_USER_ID=
# RESESH_GUILD_ID=
# RESESH_CHANNEL_ID=
# RESESH_DEEPGRAM_MODE=platform   # platform | byok | disabled
# RESESH_DEEPGRAM_KEY=             # only when mode=byok
# RESESH_SIZE=micro                # nano | micro | small
