# cfg-server-disrecord — environment.
#
# Two modes share this file:
#   worker  — legacy per-session SSE worker (core-server spawns it and
#             injects these vars; you only need them locally to debug).
#   serve   — standalone unified recording container (Phase 1). BYO bot
#             token + Deepgram key; no core-server involvement.
#
# ─────────────────────────────────────────────────────────────────────────
# serve mode (standalone container)
# ─────────────────────────────────────────────────────────────────────────

# Discord bot token + application (client) id. Create a bot at
# https://discord.com/developers/applications — enable the Server Members
# and Message Content privileged intents on the Bot tab.
DISRECORD_DISCORD_TOKEN=
DISRECORD_DISCORD_CLIENT_ID=

# Deepgram API key for live transcription. BYO — you pay Deepgram directly.
# Leave empty for record-only mode (mp3 mix, no transcript / VTT).
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=en

# Where finalized mp3 + VTT files land (one subdir per recording id).
OUTPUT_DIR=/data/recordings

# HTTP control API. Binds 127.0.0.1 only in Phase 1. CONTROL_TOKEN is
# optional — when set, every /v1/* request must carry
# `Authorization: Bearer <token>`.
CONTROL_PORT=8080
# CONTROL_TOKEN=

# `disrecord start` reads these (convenience CLI wrapper for the HTTP API).
# START_GUILD_ID=
# START_VOICE_CHANNEL_ID=
# START_TEXT_CHANNEL_ID=

LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────────────
# worker mode (legacy SSE path — core-server injects these per session)
# ─────────────────────────────────────────────────────────────────────────

# CORE_SERVER_URL=http://localhost:3001
# CORE_SERVER_TOKEN=
# DISRECORD_INSTALLATION_ID=
# DISRECORD_USER_ID=
# DISRECORD_GUILD_ID=
# DISRECORD_CHANNEL_ID=
# DISRECORD_DEEPGRAM_MODE=platform   # platform | byok | disabled
# DISRECORD_DEEPGRAM_KEY=            # only when mode=byok
# DISRECORD_SIZE=micro               # nano | micro | small
