# cfg-server-disrecord — environment.
#
# DisRecord is a "skill server" — it lets an EXISTING Discord bot gain the
# skill of "hearing" a voice call (recording + transcription). It is NOT a
# bot itself: it borrows a bot token to join voice on that bot's behalf.
#
# One `serve` mode, two configurations from the same image:
#   self-host   — no CORE_SERVER_URL. BYO bot token + Deepgram key; no
#                 core-server involvement. Recordings land in OUTPUT_DIR.
#                 Want slash commands? Build your own bot that drives this
#                 container over the HTTP control API — ReSesh is the
#                 reference implementation.
#   CFG-hosted  — CORE_SERVER_URL + per-session JWT + object-storage creds
#                 present. core-server spawns it and injects the CFG vars.
#
# ─────────────────────────────────────────────────────────────────────────
# serve mode — core settings (always required)
# ─────────────────────────────────────────────────────────────────────────

# Discord bot token. This skill server is NOT a bot — it borrows a bot
# token only to join voice and capture frames on that bot's behalf.
# Self-host: supply your own bot's token. CFG-hosted: core-server injects
# the consuming bot's (ReSesh's) token. Create a bot at
# https://discord.com/developers/applications — enable the Server Members
# and Message Content privileged intents on the Bot tab (the latter is
# used by the in-Discord consent buttons).
DISRECORD_DISCORD_TOKEN=

# Deepgram API key for live transcription. BYO — you pay Deepgram directly.
# Leave empty for record-only mode (mp3 mix, no transcript / VTT).
# CFG-hosted note: for DEEPGRAM_MODE=platform this is NOT injected — the
# container mints short-lived Deepgram grant tokens from core-server instead.
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=en

# Deepgram billing mode. Defaults to inferred-from-key when unset:
#   platform  — CFG-hosted with the platform key; container fetches a
#               short-lived grant token from core-server per websocket.
#   byok      — DEEPGRAM_API_KEY is a user-supplied key, used directly.
#   disabled  — no transcription (record-only).
# Self-host operators normally leave this unset (byok-by-key behavior).
# DEEPGRAM_MODE=

# Where finalized mp3 + VTT files land (one subdir per recording id).
OUTPUT_DIR=/data/recordings

# HTTP control API. Binds 127.0.0.1 only in self-host mode. CONTROL_TOKEN is
# optional — when set, every /v1/* request must carry
# `Authorization: Bearer <token>`.
CONTROL_PORT=8080
# CONTROL_TOKEN=

# `disrecord start` reads these (convenience CLI wrapper for the HTTP API).
# START_GUILD_ID=
# START_VOICE_CHANNEL_ID=
# START_TEXT_CHANNEL_ID=

LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────────────
# serve mode — CFG-hosted phone-home (OPTIONAL)
# ─────────────────────────────────────────────────────────────────────────
#
# Leave CORE_SERVER_URL empty for a pure self-host container — every
# phone-home path is then a clean no-op (blank-slate boot). When
# CORE_SERVER_URL IS set, core-server injects all of these at spawn time;
# the remaining CFG vars become required and the container fails loudly at
# boot if any is missing.
#
# CORE_SERVER_URL=http://localhost:3001
# CORE_SERVER_TOKEN=                 # per-session JWT (scope=disrecord-worker)
# DISRECORD_INSTALLATION_ID=         # equals the RecordingSession id
# DISRECORD_USER_ID=
# DISRECORD_CT_PER_MIN=13            # container uptime CT/min (core-server computes)
# DISRECORD_SIZE=small               # nano | micro | small (informational)
#
# Live-transcription surcharge — injected by core-server ONLY when the
# recording uses the platform Deepgram key (deepgram mode = platform). Its
# presence makes the container post a separate itemized `transcription`
# billing tick alongside the container-uptime tick. Absent for BYOK or
# disabled transcription ⇒ no surcharge, container uptime billed only.
# DISRECORD_TRANSCRIPTION_CT_PER_MIN=2
#
# Object-storage upload (any S3-compatible store) — independently optional.
# With CORE_SERVER_URL but no DO_SPACES_*, the container phones home for
# billing/consent but stores recordings locally. The DO_SPACES_* var names
# are deployed surface (core-server injects them) and are kept as-is.
# DO_SPACES_KEY=
# DO_SPACES_SECRET=
# DO_SPACES_BUCKET=
# DO_SPACES_REGION=
# DO_SPACES_ENDPOINT=
