# engine-strict matches the cfg-* convention (Node 24+, per the node:24-slim
# runtime this ships on).
engine-strict=true

# @crit-fumble scope is published to GitHub Packages.
#
# The line below only NAMES the registry — it does not bind a token to it, so
# exporting NODE_AUTH_TOKEN on its own does nothing and installs fail with
# "401 Unauthorized ... authentication token not provided". npm only picks the
# token up when a //npm.pkg.github.com/:_authToken entry exists.
#
# (Nothing here currently depends on @crit-fumble/*, so this is precautionary.)
#
# Local:
#     env "npm_config_//npm.pkg.github.com/:_authToken=$(gh auth token)" npm ci
# CI: release.yml passes a BuildKit secret id=npmrc carrying that entry — see
#     the contract in the Dockerfile header.
@crit-fumble:registry=https://npm.pkg.github.com
