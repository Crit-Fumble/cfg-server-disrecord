{
  "name": "@crit-fumble/server-disrecord",
  "version": "0.2.2",
  "private": true,
  "type": "module",
  "description": "Crit-Fumble DisRecord — self-contained Discord voice recording container. Boots its own bot, captures voice, mixes mp3, and transcribes. Runs local-only or CFG-hosted (phones home to cfg-core-server for billing/Spaces/consent).",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Crit-Fumble/cfg-server-disrecord.git"
  },
  "homepage": "https://github.com/Crit-Fumble/cfg-server-disrecord",
  "main": "./dist/index.js",
  "bin": {
    "disrecord": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env --clear-screen=false src/index.ts serve",
    "build": "tsc && tsc-alias -f",
    "start": "node dist/index.js serve",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "jest --config jest.config.cjs",
    "test:unit": "jest --config jest.config.cjs --testPathPatterns=tests/unit",
    "test:integration": "jest --config jest.config.cjs --testPathPatterns=tests/integration",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1044.0",
    "@aws-sdk/lib-storage": "^3.1044.0",
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.2",
    "discord.js": "^14.26.4",
    "fastify": "^5.8.5",
    "jose": "^6.1.0",
    "libsodium-wrappers": "^0.7.15",
    "pino": "^10.1.0",
    "tweetnacl": "^1.0.3",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@swc/core": "^1.15.33",
    "@swc/jest": "^0.2.37",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "rimraf": "^6.1.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "tar": "^7.5.15"
  }
}
