{
  "name": "@crit-fumble/server-disrecord",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Crit-Fumble DisRecord — per-session Discord voice recording worker container. Orchestrated by cfg-core-server's services/disrecord; this repo holds only the container that runs inside Docker per active session.",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Crit-Fumble/cfg-server-disrecord.git"
  },
  "homepage": "https://github.com/Crit-Fumble/cfg-server-disrecord",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env --clear-screen=false src/index.ts worker",
    "build": "tsc && tsc-alias -f",
    "start": "node dist/index.js worker",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "jest --config jest.config.cjs",
    "test:unit": "jest --config jest.config.cjs --testPathPatterns=tests/unit",
    "prepare": "husky"
  },
  "dependencies": {
    "@discordjs/opus": "^0.10.0",
    "pino": "^10.1.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@swc/core": "^1.15.33",
    "@swc/jest": "^0.2.37",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "rimraf": "^6.1.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "tar": "^7.5.15"
  }
}
