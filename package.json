{
  "name": "@crit-fumble/server-disrecord",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Crit-Fumble DisRecord — Discord voice recording + transcription server kind. Backend for the ReSesh app (Discord application 1504164101553656028).",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Crit-Fumble/cfg-server-disrecord.git"
  },
  "homepage": "https://github.com/Crit-Fumble/cfg-server-disrecord",
  "main": "./dist/index.js",
  "scripts": {
    "dev:gateway": "tsx watch --env-file=.env --clear-screen=false src/index.ts gateway",
    "dev:worker": "tsx watch --env-file=.env --clear-screen=false src/index.ts worker",
    "build": "tsc && tsc-alias -f",
    "start:gateway": "node dist/index.js gateway",
    "start:worker": "node dist/index.js worker",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "jest --config jest.config.cjs",
    "test:unit": "jest --config jest.config.cjs --testPathPatterns=tests/unit",
    "test:integration": "jest --config jest.integration.config.cjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@crit-fumble/auth": "^1.0.0",
    "@crit-fumble/shared": "^1.0.0",
    "@discordjs/opus": "^0.10.0",
    "@discordjs/rest": "^2.6.1",
    "@discordjs/voice": "^0.19.2",
    "discord.js": "^14.26.4",
    "dockerode": "^5.0.0",
    "fastify": "^5.8.5",
    "pino": "^10.1.0",
    "prism-media": "^1.3.5",
    "sodium-native": "^5.1.0",
    "tweetnacl": "^1.0.3",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@swc/core": "^1.15.33",
    "@swc/jest": "^0.2.37",
    "@types/jest": "^29.5.14",
    "@types/dockerode": "^3.3.34",
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "rimraf": "^6.1.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
